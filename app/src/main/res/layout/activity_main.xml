<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#121212" android:padding="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="منصة التحكم والأتمتة الذكية" android:textSize="22sp"
            android:textStyle="bold" android:textColor="#03DAC6"
            android:layout_gravity="center" android:layout_marginBottom="20dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1E1E1E"
            android:padding="12dp" android:layout_marginBottom="15dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="حالة الحساب والاشتراك" android:textColor="#FFBB86FC"
                android:textStyle="bold"/>
            <TextView android:id="@+id/tv_sub_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="حالة الاشتراك: نشط (ينتهي في 26-06-2027)"
                android:textColor="#4CAF50" android:layout_marginTop="5dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="رقم المعرف الرقمي: ID-99832"
                android:textColor="#AAAAAA" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1E1E1E"
            android:padding="12dp" android:layout_marginBottom="15dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="تكوين معايير التصفية التلقائية"
                android:textColor="#FFBB86FC" android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <EditText android:id="@+id/et_min_distance"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="الحد الأدنى للمسافة الحالية (كم)"
                android:textColor="#FFFFFF" android:textColorHint="#666666"
                android:inputType="numberDecimal" android:backgroundTint="#03DAC6"/>

            <EditText android:id="@+id/et_max_distance"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="الحد الأقصى للمسافة المقبولة (كم)"
                android:textColor="#FFFFFF" android:textColorHint="#666666"
                android:inputType="numberDecimal" android:backgroundTint="#03DAC6"/>

            <EditText android:id="@+id/et_min_value"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="أقل قيمة سعرية مقبولة للعملية"
                android:textColor="#FFFFFF" android:textColorHint="#666666"
                android:inputType="number" android:backgroundTint="#03DAC6"/>

            <EditText android:id="@+id/et_max_value"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="أقصى قيمة سعرية مستهدفة"
                android:textColor="#FFFFFF" android:textColorHint="#666666"
                android:inputType="number" android:backgroundTint="#03DAC6"/>
        </LinearLayout>

        <Button android:id="@+id/btn_grant_accessibility"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="1. تفعيل إذن قراءة الشاشة (Accessibility)"
            android:backgroundTint="#FF9800" android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <Button android:id="@+id/btn_launch_panel"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="2. حفظ الإعدادات وتشغيل اللوحة العائمة"
            android:backgroundTint="#03DAC6" android:textColor="#000000"
            android:layout_marginBottom="15dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1E1E1E" android:padding="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="مركز الدعم الفني وخدمة العملاء"
                android:textColor="#FFBB86FC" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="لأي استفسارات أو مشاكل تقنية، يرجى التواصل مع الإدارة مباشرة عبر القنوات المعتمدة."
                android:textColor="#DDDDDD" android:textSize="12sp" android:layout_marginTop="5dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
